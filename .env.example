############################################################
# Supabase Self-Hosted — Environment Template
#
# Copy to .env and fill in every value before first deploy.
# The easy path: run `./scripts/generate-secrets.sh > .env`
# and then edit the URL / OAuth / KONG_ALIAS fields by hand.
#
# IMPORTANT: .env is gitignored. Dokploy reads env vars from
# its own Environment tab — paste the contents of this file
# there with "Create Environment File" toggled ON.
############################################################

# ── Multi-stack disambiguation ──────────────────────────
# REQUIRED. Each Supabase stack on the same Dokploy host
# MUST have a unique KONG_ALIAS, or apps trying to reach
# `kong:8000` on the shared dokploy-network will hit a
# random stack's Kong. See README §Multi-stack.
# Convention: <project>-kong
KONG_ALIAS=CHANGEME-kong

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=postgres

# ── JWT ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-token-change-me

# Signed HS256 JWTs — see scripts/generate-secrets.sh which produces both.
# anon payload:         { "role": "anon",         "iss": "supabase", "iat": <now>, "exp": 1893456000 }
# service_role payload: { "role": "service_role", "iss": "supabase", "iat": <now>, "exp": 1893456000 }
ANON_KEY=your-anon-key-jwt
SERVICE_ROLE_KEY=your-service-role-key-jwt

# ── URLs ─────────────────────────────────────────────────
# Supabase Kong endpoint (what the browser/app hits for API calls).
# Suggested convention for multi-stack: <project>-supabase.yourdomain.com
SUPABASE_PUBLIC_URL=https://supabase.yourdomain.com
API_EXTERNAL_URL=https://supabase.yourdomain.com

# IMPORTANT: SITE_URL must point to your app, NOT the Supabase URL.
# This is where /auth/callback lives. OAuth redirects go here.
SITE_URL=https://app.yourdomain.com

# Comma-separated list of allowed redirect URLs after OAuth.
# Add localhost:3000 if you do local dev against this Supabase.
ADDITIONAL_REDIRECT_URLS=https://app.yourdomain.com/**

# ── Dashboard / Studio ───────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me-dashboard-password
# The domain you attach to the Studio service in Dokploy
# (e.g. <project>-studio.yourdomain.com). Kong uses this to
# hostname-route requests to Studio.
STUDIO_HOSTNAME=studio.yourdomain.com

# ── Auth (GoTrue) ────────────────────────────────────────
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_JWT_EXP=3600

# ── Google OAuth ─────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Each Supabase stack should have its OWN OAuth client.
# Authorized redirect URI: ${SUPABASE_PUBLIC_URL}/auth/v1/callback
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOTRUE_EXTERNAL_GOOGLE_SECRET=your-google-client-secret

# ── Storage ──────────────────────────────────────────────
# Increase if you need >50 MB uploads (default: 50 MB)
FILE_SIZE_LIMIT=52428800

# ── Misc ─────────────────────────────────────────────────
SECRET_KEY_BASE=your-secret-key-base-change-me
# Encrypts Realtime tenant credentials in the _realtime schema.
# Must be exactly 16 characters for the Realtime AES-128 encryption path.
# Generate with: openssl rand -hex 8
# IMPORTANT for existing deployments: changing this requires restarting Realtime
# and verifying subscriptions still work.
REALTIME_DB_ENC_KEY=16-char-key-here
PG_META_CRYPTO_KEY=your-pg-meta-crypto-key-change-me

############################################################
# Your app's .env (NOT this file — separate repo)
#
# NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_PUBLIC_URL}
# NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
# SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
#
# If your app server runs in the same Dokploy docker network
# as this Supabase stack:
#   SUPABASE_INTERNAL_URL=http://${KONG_ALIAS}:8000
# Bypasses Cloudflare / Traefik for server-side calls.
############################################################
